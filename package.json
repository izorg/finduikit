{
  "name": "finduikit",
  "private": true,
  "author": "Viacheslav Zavoruev<izorgster@gmail.com>",
  "type": "module",
  "sideEffects": [
    "domains/polyfills/**"
  ],
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "analyze": "next experimental-analyze",
    "build": "next build",
    "check": "yarn next-typegen && yarn check-eslint && yarn check-oxlint && yarn check-prettier && yarn check-stylelint && yarn check-tsc && yarn check-knip",
    "check-eslint": "eslint --cache",
    "check-knip": "knip --cache",
    "check-oxlint": "oxlint",
    "check-prettier": "prettier --cache --check --ignore-unknown .",
    "check-stylelint": "stylelint --allow-empty-input --cache \"**/*.css\"",
    "check-tsc": "tsc",
    "clean": "rm -rf .next/ node_modules/.cache .eslintcache .stylelintcache firestore-debug.log tsconfig.tsbuildinfo",
    "dev": "concurrently --names=\"firebase,next\" \"yarn dev-firebase\" \"yarn dev-next\"",
    "dev-firebase": "firebase emulators:start --export-on-exit --import=.firebase",
    "dev-next": "next dev",
    "format": "prettier --cache --ignore-unknown --write .",
    "generate-json-schema": "node --import=tsx --import=@nodejs-loaders/css-module domains/ui-kit/scripts/generate-json-schema.ts",
    "graphql-codegen": "node --env-file-if-exists=.env.local node_modules/.bin/graphql-codegen",
    "next-typegen": "next typegen",
    "start": "next start",
    "update-ui-kits": "node --env-file-if-exists=.env.local --import=tsx --import=@nodejs-loaders/css-module domains/ui-kit/scripts/update-ui-kits.ts"
  },
  "dependencies": {
    "@mdi/js": "7.4.47",
    "@next/third-parties": "16.2.4",
    "@radix-ui/react-compose-refs": "1.1.2",
    "@radix-ui/themes": "3.3.0",
    "@sentry/nextjs": "10.49.0",
    "classnames": "2.5.1",
    "core-js": "3.49.0",
    "emoji-toolkit": "10.0.0",
    "firebase-admin": "13.8.0",
    "fuse.js": "7.3.0",
    "linkify-plugin-mention": "4.3.2",
    "linkify-react": "4.3.2",
    "linkifyjs": "4.3.2",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "simple-icons": "16.17.0",
    "usehooks-ts": "3.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/css": "1.1.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@eslint/markdown": "8.0.1",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/near-operation-file-preset": "5.0.1",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-operations": "5.1.0",
    "@next/eslint-plugin-next": "16.2.4",
    "@nodejs-loaders/css-module": "1.2.0",
    "@prettier/plugin-xml": "3.4.2",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "9.2.1",
    "eslint": "10.2.1",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-compat": "7.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-json-schema-validator": "6.2.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-yml": "3.3.1",
    "firebase-tools": "15.15.0",
    "globals": "17.5.0",
    "graphql": "16.13.2",
    "knip": "6.4.1",
    "node-html-parser": "7.1.0",
    "oxlint": "1.60.0",
    "postcss": "8.5.10",
    "postcss-import": "16.1.1",
    "postcss-preset-env": "11.2.1",
    "prettier": "3.8.3",
    "stylelint": "17.8.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "stylelint-order": "8.1.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "typescript-plugin-css-modules": "5.2.0",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  }
}
